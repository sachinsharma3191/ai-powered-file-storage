# AI Powered File Storage - Environment Variables Example
# Copy this file to .env and customize for your environment

# =============================================================================
# FRONTEND (Angular UI)
# =============================================================================
NG_APP_API_URL=http://localhost:3000
NG_APP_OLLAMA_URL=http://ollama:11434

# =============================================================================
# BACKEND SERVICES
# =============================================================================

# Ruby Control Plane (Rails)
RAILS_ENV=development
DATABASE_URL=postgres://postgres:postgres@postgres:5432/ai_powered_file_storage_development
REDIS_URL=redis://redis:6379/0
SCOPED_JWT_SECRET=rust-integration-secret-key-2024
CHUNK_GATEWAY_BASE_URL=http://chunk-gateway:4000
CHUNK_GATEWAY_REGION=us-west-2
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,https://google.com
MAILER_HOST=localhost
MAILER_PORT=3000

# Rust Data Plane (Chunk Gateway)
BIND_ADDR=0.0.0.0
PORT=4000
SCOPED_JWT_SECRET=rust-integration-secret-key-2024
CHUNK_GATEWAY_REGION=us-west-2
REDIS_URL=redis://redis:6379/1
EVENT_STREAM=storage-events
EVENTS_ENABLED=true
DOWNLOAD_THRESHOLD=1000
METRICS_WINDOW_MINUTES=60
RUST_LOG=info

# Python Agent (Event Processing)
QUEUE_TYPE=redis_streams
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CONSUMER_GROUP=ai-powered-file-storage-agent
QUEUE_TOPICS=storage-events
MAX_RETRIES=3
BATCH_SIZE=10
PROCESSING_TIMEOUT=30

# API Connections
RUBY_API_URL=http://storage-control-plane:3000
RUST_API_URL=http://chunk-gateway:4000
API_KEY=test-api-key
API_TIMEOUT=30
MAX_CONCURRENT_ACTIONS=10
RETRY_ATTEMPTS=3
RETRY_DELAY=5

# LLM Configuration (Optional)
LLM_ENABLED=false
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_URL=http://ollama:11434

# Notification Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_ADDRESS=noreply@ai-powered-file-storage.com
SMTP_USE_TLS=true
SLACK_BOT_TOKEN=
WEBHOOK_TOKEN=
WEBHOOK_TIMEOUT=30

# Logging & Monitoring
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_PORT=8080
SENTRY_DSN=
ENVIRONMENT=development

# =============================================================================
# DOCKER COMPOSE INTERNALS
# =============================================================================

# These are used internally by Docker Compose services
NOTIFICATION_SERVICE_URL=http://notification-service:5000

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# Uncomment and modify these for production deployment:

# NG_APP_API_URL=https://api.yourdomain.com
# NG_APP_OLLAMA_URL=https://ollama.yourdomain.com
# DATABASE_URL=postgres://user:pass@prod-db:5432/production_db
# REDIS_URL=redis://prod-redis:6379/0
# SCOPED_JWT_SECRET=your-production-secret-key
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# LLM_ENABLED=true
# OPENAI_API_KEY=your-production-openai-key
# ENVIRONMENT=production
# LOG_LEVEL=WARN
